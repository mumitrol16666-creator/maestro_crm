#!/usr/bin/expect -f

set timeout 60
set server "38.180.206.183"
set user "root"
set password "LMQ2kUkBBR"

spawn scp simple-nginx-fix.sh ${user}@${server}:/tmp/simple-nginx-fix.sh
expect {
    "password:" {
        send "${password}\r"
    }
}
expect eof

spawn ssh ${user}@${server}
expect {
    "password:" {
        send "${password}\r"
    }
}

expect "# "
send "chmod +x /tmp/simple-nginx-fix.sh\r"
expect "# "
send "/tmp/simple-nginx-fix.sh\r"
expect "# "
send "exit\r"
expect eof
