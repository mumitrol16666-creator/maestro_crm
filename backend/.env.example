# PostgreSQL (Prisma)
DATABASE_URL=postgresql://maestro:your_postgres_password@localhost:5432/maestro_crm?schema=public

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis (optional, for cache/sessions)
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram Bot (optional — на сервере заполнить в .env)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS (Frontend URL)
# Локально: http://localhost:8000
# Прод:    https://app-maestro-school.duckdns.org
FRONTEND_URL=http://localhost:8000

# WhatsApp Bot (optional)
WHATSAPP_SESSION_PATH=./sessions/whatsapp

# Google Gemini AI (optional)
GEMINI_API_KEY=
