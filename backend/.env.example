# PostgreSQL (Prisma)
DATABASE_URL=postgresql://maestro:your_postgres_password@localhost:5432/maestro_crm?schema=public

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis (optional, for cache/sessions)
REDIS_HOST=localhost
REDIS_PORT=6379

# Telegram Bot (optional — на сервере заполнить в .env)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CORS (Frontend URL)
# Локально: http://localhost:8000
# Прод:    https://app-maestro-school.duckdns.org
FRONTEND_URL=http://localhost:8000

# Payment links
KASPI_PAY_LINK=https://pay.kaspi.kz/pay/ku3aldre
SCHOOL_ADDRESS=Марата Оспанова, 52/2

# WhatsApp Bot (optional)
WHATSAPP_SESSION_PATH=./sessions/whatsapp

# WhatsApp Meta Cloud API (optional)
WHATSAPP_META_VERIFY_TOKEN=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_BUSINESS_ACCOUNT_ID=
WHATSAPP_META_APP_SECRET=
WHATSAPP_META_GRAPH_VERSION=v23.0

# Google Gemini AI (optional)
GEMINI_API_KEY=

# Evening Telegram report AI comment (optional)
# Set OPENAI_API_KEY only on the server, never in git.
OPENAI_API_KEY=
EVENING_REPORT_AI_ENABLED=false
EVENING_REPORT_AI_MODEL=
EVENING_REPORT_AI_TIMEOUT_MS=12000

# Trial lesson AI analysis agent (optional)
# If TRIAL_ANALYSIS_AGENT_URL is empty, CRM generates the Word file internally via OPENAI_API_KEY.
# If you use an external endpoint, it should accept CRM JSON payload and return structured JSON analysis.
# CRM always builds the final student-facing DOCX locally and never accepts a DOCX from the agent.
# Do not point TRIAL_ANALYSIS_AGENT_URL to https://api.openai.com directly.
TRIAL_ANALYSIS_OPENAI_MODEL=gpt-4o-mini
TRIAL_ANALYSIS_OPENAI_TIMEOUT_MS=90000
TRIAL_ANALYSIS_AGENT_URL=
TRIAL_ANALYSIS_AGENT_API_KEY=
TRIAL_ANALYSIS_AGENT_TIMEOUT_MS=90000

# Integration: Learning Platform (User Link API)
INTEGRATION_SERVICE_SECRET=change-me-shared-secret-between-crm-and-app
INTEGRATION_SSO_SECRET=change-me-sso-bridge-secret
LEARNING_PLATFORM_API_URL=http://127.0.0.1:4000
LEARNING_PLATFORM_URL=https://maestro-school.duckdns.org
