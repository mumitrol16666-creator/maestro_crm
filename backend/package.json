{
  "name": "maestro-crm-backend",
  "version": "1.0.0",
  "description": "CRM API для музыкальной школы Maestro",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "npx prisma db push && nodemon src/server.js",
    "test": "node --test --test-concurrency=1 test/*.test.js",
    "test:watch": "node --test --watch --test-concurrency=1 test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-concurrency=1 test/*.test.js",
    "test:syntax": "find src test -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "keywords": [
    "maestro",
    "music-school",
    "crm",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@whiskeysockets/baileys": "^6.7.9",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.20.0",
    "pino": "^10.2.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "redis": "^4.6.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.6.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
