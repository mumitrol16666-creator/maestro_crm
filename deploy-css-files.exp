#!/usr/bin/expect -f

set timeout 60
set server "38.180.206.183"
set user "root"
set password "LMQ2kUkBBR"

puts "=== Отправка CSS файлов на сервер ==="

spawn scp frontend/css/styles.css frontend/css/admin-styles.css frontend/css/toast.css ${user}@${server}:/var/www/lgardens.ru/css/
expect {
    "password:" {
        send "${password}\r"
    }
    "yes/no" {
        send "yes\r"
        expect "password:"
        send "${password}\r"
    }
}
expect eof

puts "\n✅ CSS файлы отправлены!"
