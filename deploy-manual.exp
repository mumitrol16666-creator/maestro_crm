#!/usr/bin/expect -f

set timeout 30

spawn ssh root@senseofdance.kz

expect "password:"
send "SenseOfDance2024!\r"

expect "#"
send "cd /root/sense-of-dance\r"

expect "#"
send "git pull origin main\r"

expect "#"
send "pm2 restart sense-of-dance-frontend\r"

expect "#"
send "pm2 restart sense-of-dance-backend\r"

expect "#"
send "pm2 status\r"

expect "#"
send "exit\r"

expect eof
