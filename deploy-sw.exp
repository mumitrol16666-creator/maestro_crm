#!/usr/bin/expect -f

set timeout 60
set server "38.180.206.183"
set user "root"
set password "LMQ2kUkBBR"

puts "=== Загрузка sw.js на сервер ==="

spawn scp frontend/sw.js ${user}@${server}:/var/www/lgardens.ru/sw.js
expect {
    "password:" {
        send "${password}\r"
    }
    "yes/no" {
        send "yes\r"
        expect "password:"
        send "${password}\r"
    }
}
expect eof

puts "\n✅ Service Worker обновлен!"
