#!/usr/bin/expect -f

set timeout 30
set server "38.180.206.183"
set user "root"
set password "LMQ2kUkBBR"

spawn ssh ${user}@${server}
expect {
    "password:" {
        send "${password}\r"
    }
    "yes/no" {
        send "yes\r"
        expect "password:"
        send "${password}\r"
    }
}

expect "# "
send "cp /tmp/admin.html /var/www/lgardens.ru/admin/admin.html\r"
expect "# "
send "chmod 644 /var/www/lgardens.ru/admin/admin.html\r"
expect "# "
send "ls -lh /var/www/lgardens.ru/admin/admin.html\r"
expect "# "
send "echo \"✅ admin.html обновлен\"\r"
expect "# "
send "exit\r"
expect eof
