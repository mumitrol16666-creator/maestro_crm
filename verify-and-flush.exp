#!/usr/bin/expect -f

set timeout 60
set password "D7V7vcfK2i"
set host "root@149.33.0.114"

spawn ssh -o StrictHostKeyChecking=no $host
expect "password:"
send "$password\r"
expect "#"

# 1. Flush Redis to clear API cache
send "redis-cli FLUSHALL\r"
expect "OK"
expect "#"

# 2. Check content of the file (grep for the new comment)
send "grep -C 5 \"Фильтр по роли (должен применяться ПОСЛЕ\" /root/sense-of-dance/backend/src/routes/students.js\r"
expect "#"

send "exit\r"
expect eof
